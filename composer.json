{
    "name": "aghfatehi/laravel-saudi-fda",
    "description": "Laravel package for Saudi Food and Drug Authority (SFDA) API integration. SDK for Cosmetics, Drugs, Food & Medical Devices with OAuth2 auto-auth. ربط الهيئة العامة للغذاء والدواء السعودية مع لارافيل - دعم مستحضرات التجميل، الأدوية، المنتجات الغذائية، والأجهزة الطبية",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "sfda",
        "saudi-fda",
        "saudi-arabia",
        "الهيئة العامة للغذاء والدواء",
        "SFDA API",
        "السعودية",
        "sfda saudi arabia",
        "SFDA integration laravel",
        "SFDA cosmetics API",
        "SFDA drugs API",
        "SFDA food API",
        "SFDA medical devices API",
        "sfda api laravel package",
        "laravel",
        "لارافيل",
        "laravel package",
        "laravel api integration",
        "laravel sfda",
        "laravel saudi fda",
        "cosmetics",
        "drugs",
        "food",
        "medical devices",
        "API",
        "REST API",
        "OAuth2",
        "مستحضرات التجميل",
        "الأدوية",
        "المنتجات الغذائية",
        "الأجهزة الطبية",
        "API integration", "دمج", "التكامل",
        "riyadh", "المملكة العربية السعودية",
        "php", "composer", "packagist",
        "open source"
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Aghfatehi\\SaudiFda\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aghfatehi\\SaudiFda\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aghfatehi\\SaudiFda\\SaudiFdaServiceProvider"
            ],
            "aliases": {
                "SaudiFda": "Aghfatehi\\SaudiFda\\Facades\\SaudiFda"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "AL-AGHBARI Fatehi",
            "email": "aghfatehi@gmail.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/aghfatehi/laravel-saudi-fda/issues",
        "source": "https://github.com/aghfatehi/laravel-saudi-fda"
    }
}
